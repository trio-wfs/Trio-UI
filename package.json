{
  "name": "@trio-wfs/ui",
  "version": "1.0.0",
  "description": "TRIO WFS shared component library. React + MUI v5 components aligned to the Trio-UI design system.",
  "main": "./components/index.ts",
  "types": "./components/index.ts",
  "scripts": {
    "figma:validate": "figma connect --token $(grep FIGMA_ACCESS_TOKEN .env | cut -d= -f2)",
    "figma:publish": "figma connect publish --token $(grep FIGMA_ACCESS_TOKEN .env | cut -d= -f2)",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "@emotion/react": ">=11.0.0",
    "@emotion/styled": ">=11.0.0",
    "@mui/icons-material": ">=5.0.0",
    "@mui/material": ">=5.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@figma/code-connect": "^1.4.2",
    "storybook": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@chromatic-com/storybook": "^5.1.2",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "vitest": "^4.1.4",
    "playwright": "^1.59.1",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jszygiel1981-ship-it/Trio-UI.git"
  },
  "keywords": [
    "trio",
    "wfs",
    "design-system",
    "mui",
    "react",
    "components"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "ag-charts-community": "^13.2.1",
    "ag-charts-react": "^13.2.1"
  }
}
